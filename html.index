<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Apertura WhatsApp...</title>

  <script>
    function openWhatsApp() {
      var url = "https://wa.me/393514244519?text=" + encodeURIComponent(
        "Ciao, aggiungimi alla lista WhatsApp VIP per offerte speciali ed eventi. (Sono consapevole di dover salvare il vostro numero per ricevere i messaggi e accetto le comunicazioni marketing.)"
      );

      window.location.href = url;
    }

    // apertura automatica dopo 0.2 sec (compatibile GitHub + iPhone)
    setTimeout(openWhatsApp, 200);
  </script>

  <style>
    body{
      font-family: Arial, sans-serif;
      background:#0f0f0f;
      color:white;
      text-align:center;
      padding-top:80px;
    }
    .btn{
      background:#25D366;
      color:white;
      padding:18px 28px;
      border-radius:12px;
      text-decoration:none;
      font-size:20px;
      display:inline-block;
      margin-top:25px;
    }
  </style>
</head>

<body>

<h2>Ti stiamo collegando su WhatsApp…</h2>
<p>Se non si apre automaticamente clicca qui:</p>

<a class="btn" href="https://wa.me/393514244519?text=Ciao%2C%20aggiungimi%20alla%20lista%20WhatsApp%20VIP%20per%20offerte%20speciali%20ed%20eventi.%20(Sono%20consapevole%20di%20dover%20salvare%20il%20vostro%20numero%20per%20ricevere%20i%20messaggi%20e%20accetto%20le%20comunicazioni%20marketing.)">
Apri WhatsApp
</a>

</body>
</html>
